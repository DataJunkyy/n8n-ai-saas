    {
      "parameters": {
        "jsCode": "const rows = $input.all();\n\nif (rows.length === 0) {\n  return [{ json: { result: 'No tasks found in the tracker.' } }];\n}\n\n// Group by project, then count by status\nconst projects = {};\nfor (const row of rows) {\n  const t = row.json;\n  const project = t.Project || 'Uncategorized';\n  const status = t.Status || 'No Status';\n  if (!projects[project]) projects[project] = {};\n  projects[project][status] = (projects[project][status] || 0) + 1;\n}\n\n// Build summary text\nconst lines = ['=== Project Summary ==='];\nfor (const [project, statuses] of Object.entries(projects)) {\n  const total = Object.values(statuses).reduce((a, b) => a + b, 0);\n  lines.push(`\\n📁 ${project} (${total} task${total !== 1 ? 's' : ''})`);\n  for (const [status, count] of Object.entries(statuses)) {\n    lines.push(`   • ${status}: ${count}`);\n  }\n}\n\nconst totalAll = rows.length;\nlines.push(`\\nTotal: ${totalAll} task${totalAll !== 1 ? 's' : ''} across ${Object.keys(projects).length} project${Object.keys(projects).length !== 1 ? 's' : ''}`);\n\nreturn [{ json: { result: lines.join('\\n') } }];"
      },
      "id": "d1b2c3d4-0004-0004-0004-000000000003",
      "name": "Build Summary",
