      "name": "Enrich Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        660,
        304
      ]
    },
    {
      "parameters": {
        "agent": "conversationalAgent",
        "promptType": "define",
        "text": "={{ $json.message }}",
        "options": {
          "maxIterations": 10,
          "returnIntermediateSteps": true,
          "systemMessage": "=You are a helpful Project Management Assistant. You help manage tasks, create documents, and provide project status summaries.\n\nRESPONSE STYLE:\n- Be concise but thorough\n- Format responses as plain text (no markdown) for smartphone compatibility\n- Use line breaks and simple formatting for readability\n\nAVAILABLE TOOLS:\n- list_tasks: List tasks, optionally filtered by project name\n- manage_task: Create a new task with project, description, status, priority, due date\n- create_document: Create a Google Doc with a title and content\n- get_project_summary: Get a status overview of all projects and tasks\n\n{{ $json.learningsSection || '' }}"
        }
      },
